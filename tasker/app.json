    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#6C63FF"
      },
      "package": "com.tasker.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "sdkVersion": "55.0.0"
  }
}
